{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "local_shell|shell|shell_command|exec_command|Bash|Shell|apply_patch|Edit|Write|grep_files|ctx_execute|ctx_execute_file|ctx_batch_execute|ctx_fetch_and_index|ctx_search|ctx_index|mcp__",
        "hooks": [
          {
            "type": "command",
            "command": "env CONTEXT_MODE_PLATFORM=codex context-mode hook codex pretooluse"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "env CONTEXT_MODE_PLATFORM=codex context-mode hook codex posttooluse"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "env CONTEXT_MODE_PLATFORM=codex context-mode hook codex sessionstart"
          },
          {
            "type": "command",
            "command": "serena-hooks activate --client=codex"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "env CONTEXT_MODE_PLATFORM=codex context-mode hook codex precompact"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "env CONTEXT_MODE_PLATFORM=codex context-mode hook codex userpromptsubmit"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "env CONTEXT_MODE_PLATFORM=codex context-mode hook codex stop"
          },
          {
            "type": "command",
            "command": "serena-hooks cleanup --client=codex"
          }
        ]
      }
    ]
  }
}

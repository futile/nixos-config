@@ -0,0 +1,77 @@
+import pytest
+
+from solidlsp.language_servers.rust_analyzer import RustAnalyzer
+from solidlsp.settings import SolidLSPSettings
+
+
+def _rust_analyzer(custom_settings: dict) -> RustAnalyzer:
+    analyzer = object.__new__(RustAnalyzer)
+    analyzer._custom_settings = SolidLSPSettings.CustomLSSettings(custom_settings)
+    return analyzer
+
+
+def test_rust_analyzer_initialization_options_deep_merge() -> None:
+    params = _rust_analyzer(
+        {
+            "initializationOptions": {
+                "cargo": {
+                    "allFeatures": True,
+                },
+                "rust": {
+                    "analyzerTargetDir": True,
+                },
+                "check": {
+                    "command": "clippy",
+                    "extraArgs": ["--no-deps"],
+                },
+                "diagnostics": {
+                    "experimental": {"enable": True},
+                },
+                "procMacro": {
+                    "ignored": {"async-trait": {}},
+                },
+            }
+        }
+    )._create_base_initialize_params()
+
+    options = params["initializationOptions"]
+    assert options["cargo"]["allFeatures"] is True
+    assert options["cargo"]["buildScripts"]["enable"] is True
+    assert options["rust"]["analyzerTargetDir"] is True
+    assert options["check"]["command"] == "clippy"
+    assert options["check"]["extraArgs"] == ["--no-deps"]
+    assert options["diagnostics"]["experimental"]["enable"] is True
+    assert options["procMacro"]["ignored"] == {"async-trait": {}}
+
+
+def test_rust_analyzer_initialization_options_replace_lists() -> None:
+    params = _rust_analyzer(
+        {
+            "initializationOptions": {
+                "files": {
+                    "excludeDirs": [
+                        ".direnv",
+                        ".git",
+                        ".jj",
+                        ".github",
+                        ".gitlab",
+                        "node_modules",
+                        "target",
+                        "venv",
+                        ".venv",
+                    ],
+                },
+            },
+        }
+    )._create_base_initialize_params()
+
+    assert params["initializationOptions"]["files"]["excludeDirs"] == [
+        ".direnv",
+        ".git",
+        ".jj",
+        ".github",
+        ".gitlab",
+        "node_modules",
+        "target",
+        "venv",
+        ".venv",
+    ]
+
+
+def test_rust_analyzer_initialization_options_must_be_mapping() -> None:
+    with pytest.raises(ValueError, match="initializationOptions must be a mapping"):
+        _rust_analyzer({"initializationOptions": []})._create_base_initialize_params()

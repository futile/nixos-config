diff --git a/b/test/solidlsp/rust/test_rust_analyzer_settings.py b/test/solidlsp/rust/test_rust_analyzer_settings.py
new file mode 100644
index 0000000..767961b
--- /dev/null
+++ b/test/solidlsp/rust/test_rust_analyzer_settings.py
@@ -0,0 +1,65 @@
+from solidlsp.language_servers.rust_analyzer import RustAnalyzer
+
+
+def test_rust_analyzer_initialization_options_deep_merge() -> None:
+    params = RustAnalyzer._get_initialize_params(
+        "/tmp/project",
+        {
+            "cargo": {
+                "allFeatures": True,
+            },
+            "rust": {
+                "analyzerTargetDir": True,
+            },
+            "check": {
+                "command": "clippy",
+                "extraArgs": ["--no-deps"],
+            },
+            "diagnostics": {
+                "experimental": {"enable": True},
+            },
+            "procMacro": {
+                "ignored": {"async-trait": {}},
+            },
+        },
+    )
+
+    options = params["initializationOptions"]
+    assert options["cargo"]["allFeatures"] is True
+    assert options["cargo"]["buildScripts"]["enable"] is True
+    assert options["rust"]["analyzerTargetDir"] is True
+    assert options["check"]["command"] == "clippy"
+    assert options["check"]["extraArgs"] == ["--no-deps"]
+    assert options["diagnostics"]["experimental"]["enable"] is True
+    assert options["procMacro"]["ignored"] == {"async-trait": {}}
+
+
+def test_rust_analyzer_initialization_options_replace_lists() -> None:
+    params = RustAnalyzer._get_initialize_params(
+        "/tmp/project",
+        {
+            "files": {
+                "exclude": [
+                    ".direnv",
+                    ".git",
+                    ".jj",
+                    ".github",
+                    ".gitlab",
+                    "node_modules",
+                    "target",
+                    "venv",
+                    ".venv",
+                ],
+            },
+        },
+    )
+
+    assert params["initializationOptions"]["files"]["exclude"] == [
+        ".direnv",
+        ".git",
+        ".jj",
+        ".github",
+        ".gitlab",
+        "node_modules",
+        "target",
+        "venv",
+        ".venv",
+    ]

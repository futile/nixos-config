#!/usr/bin/env bash
# Clear Noctalia notification history and local mappings for one WezTerm pane.
# See docs/codex-cli-wezterm-noctalia-notifications.md for the full flow.
set -euo pipefail

pane="${1:?pane id required}"
window_id="${2:-}"
if [[ "${window_id}" =~ ^[0-9]+$ ]]; then
	pane_key="${window_id}-${pane}"
else
	pane_key="${pane}"
fi
app_name="Codex pane ${pane_key}"
default_state_dir="${XDG_RUNTIME_DIR:-}"
if [[ -n "${default_state_dir}" ]]; then
	default_state_dir="${default_state_dir}/codex-noctalia"
else
	default_state_dir="/tmp/codex-noctalia-${UID}"
fi

state_dir="${CODEX_NOCTALIA_STATE_DIR:-${default_state_dir}}"
fallback_state_dir="/tmp/codex-noctalia-${UID}"

noctalia_shell="${NOCTALIA_SHELL:-noctalia-shell}"

state_dirs=("${state_dir}")
if [[ "${state_dir}" != "${fallback_state_dir}" ]]; then
	state_dirs+=("${fallback_state_dir}")
fi

close_notification() {
	local notification_id="${1:?notification id required}"

	if [[ ! "${notification_id}" =~ ^[0-9]+$ ]]; then
		return 0
	fi

	gdbus call \
		--session \
		--dest org.freedesktop.Notifications \
		--object-path /org/freedesktop/Notifications \
		--method org.freedesktop.Notifications.CloseNotification \
		"${notification_id}" >/dev/null 2>&1 || true
}

for candidate_state_dir in "${state_dirs[@]}"; do
	mkdir -p "${candidate_state_dir}" 2>/dev/null || true
	chmod 700 "${candidate_state_dir}" 2>/dev/null || true
	rm -f "${candidate_state_dir}/ready-panes/${pane}" "${candidate_state_dir}/ready-panes/${pane_key}"
	if [[ "${pane_key}" == "${pane}" ]]; then
		rm -f "${candidate_state_dir}"/ready-panes/*-"${pane}" 2>/dev/null || true
	fi
done

for candidate_state_dir in "${state_dirs[@]}"; do
	map_file="${candidate_state_dir}/notifications.tsv"

	if [[ -f "${map_file}" ]]; then
		awk -v pane="${pane}" -v pane_key="${pane_key}" '
			$2 == pane_key || $2 == pane || $3 == pane { print $1 }
		' "${map_file}" |
			while IFS= read -r notification_id; do
				close_notification "${notification_id}"
			done
	fi
done

"${noctalia_shell}" ipc call notifications getHistory |
	jq -r --arg app_name "${app_name}" '
		.[]?
		| select(.appName == $app_name)
		| .id
	' |
	while IFS= read -r notification_id; do
		if [[ -n "${notification_id}" ]]; then
			close_notification "${notification_id}"
			"${noctalia_shell}" ipc call notifications removeFromHistory "${notification_id}" >/dev/null
		fi
	done

for candidate_state_dir in "${state_dirs[@]}"; do
	map_file="${candidate_state_dir}/notifications.tsv"
	lock_file="${candidate_state_dir}/notifications.lock"

	if [[ -f "${map_file}" ]]; then
		(
			flock 9
			tmp_file="$(mktemp "${map_file}.XXXXXX")"
			awk -v pane="${pane}" -v pane_key="${pane_key}" '
				$2 != pane_key && $2 != pane && $3 != pane
			' "${map_file}" >"${tmp_file}"
			mv "${tmp_file}" "${map_file}"
		) 9>"${lock_file}"
	fi
done

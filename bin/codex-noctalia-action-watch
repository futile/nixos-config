#!/usr/bin/env bash
# Watch notification click actions and activate the mapped WezTerm pane.
# See docs/codex-cli-wezterm-noctalia-notifications.md for the full flow.
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
default_state_dir="${XDG_RUNTIME_DIR:-}"
if [[ -n "${default_state_dir}" ]]; then
	default_state_dir="${default_state_dir}/codex-noctalia"
else
	default_state_dir="/tmp/codex-noctalia-${UID}"
fi

state_dir="${CODEX_NOCTALIA_STATE_DIR:-${default_state_dir}}"
fallback_state_dir="/tmp/codex-noctalia-${UID}"

state_dirs=("${state_dir}")
if [[ "${state_dir}" != "${fallback_state_dir}" ]]; then
	state_dirs+=("${fallback_state_dir}")
fi

for candidate_state_dir in "${state_dirs[@]}"; do
	mkdir -p "${candidate_state_dir}" 2>/dev/null || true
	chmod 700 "${candidate_state_dir}" 2>/dev/null || true
done

focus_wezterm_window_for_pane() {
	local pane="${1:?pane id required}"
	local window_title
	local niri_window_id

	if ! command -v niri >/dev/null 2>&1; then
		return 0
	fi

	window_title="$(
		wezterm cli list --format json 2>/dev/null |
			jq -r --arg pane "${pane}" '
				.[]?
				| select((.pane_id | tostring) == $pane)
				| .window_title // .title // empty
			' |
			head -n 1
	)" || window_title=""

	if [[ -z "${window_title}" ]]; then
		return 0
	fi

	niri_window_id="$(
		niri msg -j windows 2>/dev/null |
			jq -r --arg title "${window_title}" '
				.[]?
				| select(.app_id == "org.wezfurlong.wezterm")
				| select(.title == $title or (.title | endswith($title)))
				| .id
			' |
			head -n 1
	)" || niri_window_id=""

	if [[ ! "${niri_window_id}" =~ ^[0-9]+$ ]]; then
		return 0
	fi

	printf 'codex-noctalia-action-watch: focusing niri window %s for pane %s\n' "${niri_window_id}" "${pane}" >&2
	niri msg action focus-window --id "${niri_window_id}" >/dev/null 2>&1 || true
}

activate_pane_for_notification() {
	local notification_id="${1:?notification id required}"
	local pane
	local window_id

	for candidate_state_dir in "${state_dirs[@]}"; do
		pane="$(
			awk -v id="${notification_id}" '
				$1 == id {
					if ($3 ~ /^[0-9]+$/) {
						pane = $3
					} else {
						pane = $2
					}
				}
				END { print pane }
			' "${candidate_state_dir}/notifications.tsv" 2>/dev/null || true
		)"
		window_id="$(
			awk -v id="${notification_id}" '
				$1 == id && $2 ~ /^[0-9]+-[0-9]+$/ {
					split($2, parts, "-")
					window_id = parts[1]
				}
				END { print window_id }
			' "${candidate_state_dir}/notifications.tsv" 2>/dev/null || true
		)"
		if [[ "${pane}" =~ ^[0-9]+$ ]]; then
			break
		fi
	done

	if [[ ! "${pane}" =~ ^[0-9]+$ ]]; then
		return 0
	fi

	printf 'codex-noctalia-action-watch: notification %s activates pane %s\n' "${notification_id}" "${pane}" >&2
	wezterm cli activate-pane --pane-id "${pane}" >/dev/null 2>&1 || true
	focus_wezterm_window_for_pane "${pane}"
	if [[ "${window_id}" =~ ^[0-9]+$ ]]; then
		"${script_dir}/codex-clear-noctalia-for-pane" "${pane}" "${window_id}" || true
	else
		"${script_dir}/codex-clear-noctalia-for-pane" "${pane}" || true
	fi
}

remove_notification_mapping() {
	local notification_id="${1:?notification id required}"

	for candidate_state_dir in "${state_dirs[@]}"; do
		map_file="${candidate_state_dir}/notifications.tsv"
		lock_file="${candidate_state_dir}/notifications.lock"

		if [[ ! -f "${map_file}" ]]; then
			continue
		fi

		(
			flock 9
			tmp_file="$(mktemp "${map_file}.XXXXXX")"
			awk -v id="${notification_id}" '$1 != id' "${map_file}" >"${tmp_file}"
			mv "${tmp_file}" "${map_file}"
		) 9>"${lock_file}"
	done
}

while true; do
	gdbus monitor \
		--session \
		--dest org.freedesktop.Notifications \
		--object-path /org/freedesktop/Notifications 2>/dev/null |
		while IFS= read -r line; do
			notification_id="$(sed -n "s/.*ActionInvoked (uint32 \([0-9][0-9]*\), 'default').*/\1/p" <<<"${line}")"
			if [[ -n "${notification_id}" ]]; then
				activate_pane_for_notification "${notification_id}"
				remove_notification_mapping "${notification_id}"
			fi
		done

	sleep 1
done

#!/usr/bin/env bash
# Watch notification click actions and activate the mapped WezTerm pane.
# See docs/codex-cli-wezterm-noctalia-notifications.md for the full flow.
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
state_dir="${CODEX_NOCTALIA_STATE_DIR:-/tmp/codex-noctalia-${UID}}"
map_file="${state_dir}/notifications.tsv"
lock_file="${state_dir}/notifications.lock"

mkdir -p "${state_dir}"
chmod 700 "${state_dir}"

activate_pane_for_notification() {
	local notification_id="${1:?notification id required}"
	local pane

	pane="$(awk -v id="${notification_id}" '$1 == id { pane = $2 } END { print pane }' "${map_file}" 2>/dev/null || true)"
	if [[ ! "${pane}" =~ ^[0-9]+$ ]]; then
		return 0
	fi

	printf 'codex-noctalia-action-watch: notification %s activates pane %s\n' "${notification_id}" "${pane}" >&2
	wezterm cli activate-pane --pane-id "${pane}" >/dev/null 2>&1 || true
	"${script_dir}/codex-clear-noctalia-for-pane" "${pane}" || true
}

remove_notification_mapping() {
	local notification_id="${1:?notification id required}"

	if [[ ! -f "${map_file}" ]]; then
		return 0
	fi

	(
		flock 9
		tmp_file="$(mktemp "${map_file}.XXXXXX")"
		awk -v id="${notification_id}" '$1 != id' "${map_file}" >"${tmp_file}"
		mv "${tmp_file}" "${map_file}"
	) 9>"${lock_file}"
}

while true; do
	gdbus monitor \
		--session \
		--dest org.freedesktop.Notifications \
		--object-path /org/freedesktop/Notifications 2>/dev/null |
		while IFS= read -r line; do
			notification_id="$(sed -n "s/.*ActionInvoked (uint32 \([0-9][0-9]*\), 'default').*/\1/p" <<<"${line}")"
			if [[ -n "${notification_id}" ]]; then
				activate_pane_for_notification "${notification_id}"
				remove_notification_mapping "${notification_id}"
			fi
		done

	sleep 1
done

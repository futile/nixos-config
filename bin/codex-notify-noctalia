#!/usr/bin/env bash
# Send pane-tagged Codex turn-complete notifications for Noctalia.
# See docs/codex-cli-wezterm-noctalia-notifications.md for the full flow.
set -euo pipefail

payload="${1:-}"
if [[ -z "${payload}" ]]; then
	payload="$(cat)"
fi

event_type="$(jq -r '.type // empty' <<<"${payload}")"
if [[ "${event_type}" != "agent-turn-complete" ]]; then
	exit 0
fi

pane="${WEZTERM_PANE:-}"
if [[ -z "${pane}" ]]; then
	exit 0
fi

default_state_dir="${XDG_RUNTIME_DIR:-}"
if [[ -n "${default_state_dir}" ]]; then
	default_state_dir="${default_state_dir}/codex-noctalia"
else
	default_state_dir="/tmp/codex-noctalia-${UID}"
fi
fallback_state_dir="/tmp/codex-noctalia-${UID}"

state_dir="${CODEX_NOCTALIA_STATE_DIR:-${default_state_dir}}"
ready_dir="${state_dir}/ready-panes"
map_file="${state_dir}/notifications.tsv"
lock_file="${state_dir}/notifications.lock"

prepare_state_dir() {
	local candidate="${1:?state dir required}"

	mkdir -p "${candidate}" "${candidate}/ready-panes" 2>/dev/null &&
		chmod 700 "${candidate}" 2>/dev/null &&
		touch "${candidate}/.write-test" 2>/dev/null &&
		rm -f "${candidate}/.write-test" 2>/dev/null
}

focused_panes="$(
	clients_json="$(wezterm cli list-clients --format json 2>/dev/null)" || exit 0

	if command -v niri >/dev/null 2>&1 && focused_window_json="$(niri msg -j focused-window 2>/dev/null)"; then
		focused_wezterm_pid="$(
			jq -r '.pid // empty' <<<"${focused_window_json}" 2>/dev/null
		)"

		if [[ "${focused_wezterm_pid}" =~ ^[0-9]+$ ]]; then
			jq -r --argjson pid "${focused_wezterm_pid}" '
				.[]?
				| select(.pid == $pid)
				| .focused_pane_id // empty
			' <<<"${clients_json}" 2>/dev/null
		fi
	else
		jq -r '.[].focused_pane_id // empty' <<<"${clients_json}" 2>/dev/null
	fi
)" || focused_panes=""

if grep -qxF "${pane}" <<<"${focused_panes}"; then
	exit 0
fi

summary="Codex turn complete"
repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
pane_info_json="$(
	wezterm cli list --format json 2>/dev/null |
		jq -c --arg pane "${pane}" '
			[.[]? | select((.pane_id | tostring) == $pane)][0] // {}
		'
)" || pane_info_json="{}"
window_id="$(jq -r '.window_id // empty' <<<"${pane_info_json}")"
if [[ "${window_id}" =~ ^[0-9]+$ ]]; then
	pane_key="${window_id}-${pane}"
else
	pane_key="${pane}"
fi
app_name="Codex pane ${pane_key}"
body="$(
	jq -r '
		[
			.tab_title,
			.title,
			(.cwd? // "" | split("/") | last)
		]
		| map(select(type == "string" and length > 0))
		| .[0] // empty
	' <<<"${pane_info_json}" |
		head -n 1 |
		tr '\n' ' ' |
		sed -E 's/[[:space:]]+/ /g; s/^ //; s/ $//' |
		cut -c 1-120
)" || body=""
if [[ -z "${body}" ]]; then
	body="Ready"
fi

if ! prepare_state_dir "${state_dir}"; then
	state_dir="${fallback_state_dir}"
	ready_dir="${state_dir}/ready-panes"
	map_file="${state_dir}/notifications.tsv"
	lock_file="${state_dir}/notifications.lock"
	prepare_state_dir "${state_dir}" || exit 1
fi

touch "${ready_dir}/${pane_key}"

icon_variant="light"
if command -v gsettings >/dev/null 2>&1; then
	color_scheme="$(gsettings get org.gnome.desktop.interface color-scheme 2>/dev/null || true)"
	if [[ "${color_scheme}" == *dark* ]]; then
		icon_variant="dark"
	fi
elif [[ -r "${repo_root}/dotfiles/noctalia/nixos-work/settings.json" ]]; then
	if jq -e '.colorSchemes.darkMode == true' "${repo_root}/dotfiles/noctalia/nixos-work/settings.json" >/dev/null 2>&1; then
		icon_variant="dark"
	fi
fi

app_icon="${repo_root}/dotfiles/codex/icons/codex-${icon_variant}.svg"
if [[ ! -r "${app_icon}" ]]; then
	app_icon=""
fi

notification_result="$(
	gdbus call \
	--session \
	--dest org.freedesktop.Notifications \
	--object-path /org/freedesktop/Notifications \
	--method org.freedesktop.Notifications.Notify \
	"${app_name}" \
	0 \
	"${app_icon}" \
	"${summary}" \
	"${body}" \
	"['default', 'Open pane']" \
	"{}" \
	8000
)"

notification_id="$(sed -n 's/^(uint32 \([0-9][0-9]*\),)$/\1/p' <<<"${notification_result}")"
if [[ -n "${notification_id}" ]]; then
	(
		flock 9
		printf '%s\t%s\t%s\t%s\n' "${notification_id}" "${pane_key}" "${pane}" "$(date +%s)" >>"${map_file}"
	) 9>"${lock_file}"
fi

#!/usr/bin/env bash
# Remove Noctalia history entries tagged by kitty notifications.py.
# See docs/superpowers/plans/2026-06-04-kitty-noctalia-notification-footers.md.
set -euo pipefail

source_key="${1:?source key required}"
footer="Kitty-Source: ${source_key}"
noctalia_cmd="${NOCTALIA_CMD:-noctalia}"

"${noctalia_cmd}" msg notifications getHistory |
	jq -r --arg footer "${footer}" '
		.[]?
		| select((.body // "") | contains($footer))
		| .id
	' |
	while IFS= read -r notification_id; do
		if [[ -n "${notification_id}" ]]; then
			"${noctalia_cmd}" msg notifications removeFromHistory "${notification_id}" >/dev/null
		fi
	done

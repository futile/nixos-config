#!/usr/bin/env bash
set -euo pipefail

busctl_bin="${BUSCTL_BIN:-busctl}"
noctalia_shell_bin="${NOCTALIA_SHELL_BIN:-noctalia-shell}"

log() {
  printf 'noctalia-lock-before-sleep: %s\n' "$*" >&2
}

wait_for_prepare_for_sleep() {
  "$busctl_bin" --system monitor \
    "--match=type='signal',path='/org/freedesktop/login1',interface='org.freedesktop.login1.Manager',member='PrepareForSleep'" \
    | awk '
      /Member=PrepareForSleep/ {
        in_prepare_for_sleep = 1
        next
      }

      in_prepare_for_sleep && /BOOLEAN true/ {
        found = 1
        exit 0
      }

      in_prepare_for_sleep && /BOOLEAN false/ {
        in_prepare_for_sleep = 0
      }

      END {
        if (!found) {
          exit 1
        }
      }
    '
}

lock_noctalia() {
  "$noctalia_shell_bin" ipc call lockScreen lock
}

case "${1:-}" in
  --wait-once | "")
    log "waiting for PrepareForSleep(true)"
    wait_for_prepare_for_sleep
    log "locking Noctalia screen"
    lock_noctalia
    ;;
  *)
    printf 'usage: %s [--wait-once]\n' "$0" >&2
    exit 64
    ;;
esac
